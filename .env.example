EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id-here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id-here

